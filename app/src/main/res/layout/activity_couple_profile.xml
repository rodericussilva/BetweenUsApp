<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_welcome"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 💕 TOPO -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <!-- Banner -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/banner_placeholder" />

            <!-- Fotos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgUser"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_marginEnd="-24dp"
                    android:background="@drawable/circle_placeholder"
                    android:elevation="10dp" />

                <ImageView
                    android:id="@+id/imgPartner"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/circle_placeholder"
                    android:elevation="10dp" />

            </LinearLayout>

        </FrameLayout>

        <!-- 💗 NOME DO CASAL -->
        <TextView
            android:id="@+id/tvCoupleName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User1 ❤️ User2"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#111"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"/>

        <!-- ⏳ TEMPO JUNTOS -->
        <TextView
            android:id="@+id/tvTogetherTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginTop="7dp"
            android:layout_marginBottom="24dp"
            android:text="Juntos há 31 dias"
            android:textColor="#FFFFFF"
            android:elevation="12dp"
            android:textSize="14sp"
            android:gravity="center"
            android:textAlignment="center"
            android:maxLines="3"/>

        <!-- 📅 DATAS IMPORTANTES -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:elevation="6dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Datas importantes"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvBirthdays"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aniversários: —"
                    android:textSize="15sp"
                    android:textColor="#444"/>

                <TextView
                    android:id="@+id/tvRelationshipStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Início do namoro: —"
                    android:textSize="15sp"
                    android:textColor="#444"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 📍 ENDEREÇOS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:elevation="6dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Endereços cadastrados:"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#111"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/containerAddresses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:textColor="#444"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 💞 LINGUAGENS DO AMOR -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:elevation="6dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Linguagens do Amor"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvLoveLanguages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="15sp"
                    android:textColor="#444"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
